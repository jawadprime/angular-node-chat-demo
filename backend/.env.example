# Azure Communication Services connection string (ACS resource -> "Keys" blade).
# The endpoint is parsed automatically from this value.
ACS_CONNECTION_STRING=endpoint=https://<your-acs>.communication.azure.com/;accesskey=<key>

# HTTP port the backend listens on.
PORT=3000

# MongoDB connection (chat identity mapping).
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=viewdu_chat
